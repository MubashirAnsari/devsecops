<!-- ossec_integration.xml -->
<!-- Part of: cspm-aws-wazuh pipeline -->
<!--                                                  -->
<!-- Add these blocks to /var/ossec/etc/ossec.conf    -->
<!-- on your Wazuh manager                            -->

<!-- 1. Add to prowler-vm agent ossec.conf -->
<!-- Monitor the Prowler findings file -->
<localfile>
  <log_format>json</log_format>
  <location>/var/ossec/logs/prowler_findings.json</location>
</localfile>

<!-- 2. Add to Wazuh manager ossec.conf -->
<!-- Trigger integration on critical CSPM findings -->
<integration>
  <name>custom-gchat-prowler</name>
  <group>cspm,critical</group>
  <alert_format>json</alert_format>
</integration>
